\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Mitigation method families with evidence grades. Evidence grades: \textbf  {Strong} ($\geq $3 positive studies, multi-site validation); \textbf  {Moderate} (2+ positive studies or single large-scale study); \textbf  {Mixed} (contradictory results across studies, or effective for workflow/technical goals but not for bias removal); \textbf  {Emerging} ($\leq $2 studies, limited validation); \textbf  {Failed} (methods that showed no improvement or degraded fairness in controlled evaluations). Citations shown are representative; textual references to ``more than X studies'' indicate cumulative evidence base across the broader literature.}}{7}{table.2}\protected@file@percent }
\newlabel{tab:mitigation_summary}{{2}{7}{Mitigation method families with evidence grades. Evidence grades: \textbf {Strong} ($\geq $3 positive studies, multi-site validation); \textbf {Moderate} (2+ positive studies or single large-scale study); \textbf {Mixed} (contradictory results across studies, or effective for workflow/technical goals but not for bias removal); \textbf {Emerging} ($\leq $2 studies, limited validation); \textbf {Failed} (methods that showed no improvement or degraded fairness in controlled evaluations). Citations shown are representative; textual references to ``more than X studies'' indicate cumulative evidence base across the broader literature}{table.2}{}}
