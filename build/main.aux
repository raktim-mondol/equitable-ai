\@writefile{toc}{\contentsline {section}{\numberline {C}Asymmetric Fairness-Metric Reporting Across the Corpus}{26}{appendix.1.C}\protected@file@percent }
\newlabel{app:S3}{{C}{26}{Asymmetric Fairness-Metric Reporting Across the Corpus}{appendix.1.C}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \textbf  {Asymmetric reporting of performance versus fairness metrics across the 78 included histopathology studies.} Reporting rates are from systematic audit of the full analytical corpus. Aggregate performance metrics (accuracy 85.9\%, AUROC 70.5\%, $F_1$ 42.3\%) are near-universally reported, whereas any fairness-specific metric appears in only 19.2\% of studies ($n=15$). Worst-group accuracy/AUC --- the minimum fairness guarantee demanded by recent regulatory guidance --- is reported in only 7.7\% ($n=6$ studies); Expected Calibration Error~(ECE) in 2.6\% ($n=2$); and the \emph  {subgroup calibration gap} in none. The dashed vertical rule separates standard performance metrics (left, blue) from fairness metrics (right, red). This reporting asymmetry implies that the empirical base for evaluating debiasing is drawn from a small, selection-biased subset and is the principal reason that evidence grades in Figure~\ref {fig:mitigation_grid} and Table~\ref {tab:mitigation_summary} rest on a limited number of studies.}}{26}{figure.5}\protected@file@percent }
\newlabel{fig:metric_reporting}{{5}{26}{\textbf {Asymmetric reporting of performance versus fairness metrics across the 78 included histopathology studies.} Reporting rates are from systematic audit of the full analytical corpus. Aggregate performance metrics (accuracy 85.9\%, AUROC 70.5\%, $F_1$ 42.3\%) are near-universally reported, whereas any fairness-specific metric appears in only 19.2\% of studies ($n=15$). Worst-group accuracy/AUC --- the minimum fairness guarantee demanded by recent regulatory guidance --- is reported in only 7.7\% ($n=6$ studies); Expected Calibration Error~(ECE) in 2.6\% ($n=2$); and the \emph {subgroup calibration gap} in none. The dashed vertical rule separates standard performance metrics (left, blue) from fairness metrics (right, red). This reporting asymmetry implies that the empirical base for evaluating debiasing is drawn from a small, selection-biased subset and is the principal reason that evidence grades in Figure~\ref {fig:mitigation_grid} and Table~\ref {tab:mitigation_summary} rest on a limited number of studies}{figure.5}{}}
\gdef \@abspage@last{26}
